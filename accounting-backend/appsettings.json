{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/accounting-app-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "AccountingApp"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "172.16.2.247:3000",
    "172.16.2.72:3000"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Host=172.16.2.107;Port=5432;Database=AccountingDB;Username=webadmin;Password=ADXasq81806"
  },
  "JwtSettings": {
    "SecretKey": "change-this-to-a-long-random-secret-in-production-min-32-chars",
    "ExpirationInMinutes": 60
  },
  "OAuth2": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": ""
    }
  }
}
